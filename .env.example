NEXT_PUBLIC_HERALD_PROGRAM_ID=
NEXT_PUBLIC_RPC_CLUSTER="mainnet-beta"
NEXT_PUBLIC_SOLANA_RPC_URL= # Overrides cluster-based RPC URL (e.g., https://sol-mainnet-rpc.rpcfast.com?api_key=xxxxxxxxx)
NEXT_PUBLIC_SOLANA_WSS_URL= # WebSocket endpoint for confirmTransaction (e.g., wss://sol-mainnet-rpc.rpcfast.com?api_key=xxxxxxxxx)
NEXT_PUBLIC_API_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# -- Herald Gateway Encryption (Production) --
# X25519 public key of the Herald Notification Gateway (hex-encoded 32 bytes).
# Corresponds to HERALD_X25519_PRIV_HEX stored in AWS Secrets Manager.
# Generate keypair: node -e "const nacl=require('tweetnacl'); const kp=nacl.box.keyPair(); console.log('priv:', Buffer.from(kp.secretKey).toString('hex')); console.log('pub:', Buffer.from(kp.publicKey).toString('hex'));"
NEXT_PUBLIC_HERALD_ENCLAVE_PUBKEY_HEX=
